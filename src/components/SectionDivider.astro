---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="max-w-[1200px] mx-auto px-6 py-4">
  <div class="flex items-center gap-4">
    <span class="section-label">// {label}</span>
    <div class="flex-1 dither-divider"></div>
    <span class="reg-mark"></span>
  </div>
</div>
